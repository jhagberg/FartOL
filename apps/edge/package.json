{
  "name": "@fartol/edge",
  "version": "0.0.0",
  "description": "FartOL edge bridge — Fastify HTTP/WS server + SQLite event log + SportIdent bridge",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs"
    }
  },
  "bin": {
    "fartol": "./dist/bin/fartol.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/bin/fartol.ts",
    "test": "node --test --test-reporter=spec --import tsx 'src/**/*.test.ts'",
    "test:watch": "node --test --watch --test-reporter=spec --import tsx 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fartol/shared-types": "workspace:*",
    "@fartol/sportident": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.3.5",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3",
    "ws": "^8.20.1"
  }
}
